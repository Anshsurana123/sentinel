// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  DISCORD
  CANVAS
  WHATSAPP
  SYSTEM
  WEBHOOK
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model UniversalTask {
  id          String     @id @default(uuid())
  fingerprint String     @unique
  source      SourceType
  externalId  String
  title       String
  content     String?
  priority    Priority
  metadata    Json       @default("{}")
  createdAt   DateTime   @default(now())
  expiresAt   DateTime?
  updatedAt   DateTime   @updatedAt

  @@index([fingerprint])
  @@index([source])
}

model GlobalSettings {
  id              String   @id @default("singleton")
  studyModeActive Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model SystemState {
  id                 String   @id @default("global")
  whatsappQr         String?
  whatsappConnected  Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

/// Stores a PDF uploaded to the Gemini File API for exact-match extraction.
model Paper {
  id            String   @id @default(cuid())
  title         String
  geminiUri     String?  /// The Gemini File API URI (e.g. "files/abc123")
  geminiFileId  String?  /// The file resource name, used for deletion
  pageCount     Int?     /// Optional page count for UI display
  uploadedAt    DateTime @default(now())

  @@index([title])
}
