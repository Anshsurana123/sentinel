// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  DISCORD
  CANVAS
  WHATSAPP
  SYSTEM
  WEBHOOK
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model UniversalTask {
  id          String     @id @default(uuid())
  fingerprint String     @unique
  source      SourceType
  externalId  String
  title       String
  content     String?
  priority    Priority
  metadata    Json       @default("{}")
  createdAt   DateTime   @default(now())
  expiresAt   DateTime?
  updatedAt   DateTime   @updatedAt

  @@index([fingerprint])
  @@index([source])
}

model GlobalSettings {
  id              String   @id @default("singleton")
  studyModeActive Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model SystemState {
  id                 String   @id @default("global")
  whatsappQr         String?
  whatsappConnected  Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

/// Stores a PDF uploaded to the Gemini File API for exact-match extraction.
model Paper {
  id            String   @id @default(cuid())
  title         String
  geminiUri     String?  /// The Gemini File API URI (e.g. "files/abc123")
  geminiFileId  String?  /// The file resource name, used for deletion
  supabaseUrl   String?  /// Supabase Storage public URL for PDF preview
  pageCount     Int?     /// Optional page count for UI display
  userId        String?
  uploadedAt    DateTime @default(now())
  claims        Claim[]

  @@index([title])
  @@index([userId])
}

model Claim {
  id            String   @id @default(cuid())
  text          String
  verdict       String   // "SUPPORTS" | "REFUTES" | "UNRELATED"
  exactSentence String?
  pageNumber    Int?
  context       String?
  paperId       String
  paper         Paper    @relation(fields: [paperId], references: [id])
  parentId      String?  // for citation chains
  parent        Claim?   @relation("ClaimChain", fields: [parentId], references: [id])
  children      Claim[]  @relation("ClaimChain")
  createdAt     DateTime @default(now())

  @@index([paperId])
  @@index([parentId])
}

model AcademicEvent {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  eventType   String   // "exam" | "mock" | "test" | "deadline" | "other"
  subject     String?
  date        DateTime
  daysAway    Int?     // recomputed daily
  source      String?  // timetable file name
  createdAt   DateTime @default(now())
  studyPlans  StudyPlan[]

  @@index([date])
}

model StudyPlan {
  id              String        @id @default(cuid())
  eventId         String
  event           AcademicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uncoveredTopics String
  generatedPlan   Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  progress        DayProgress[]
}

model DayProgress {
  id          String    @id @default(cuid())
  planId      String
  plan        StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayIndex    Int
  completed   Boolean   @default(false)
  completedAt DateTime?

  @@unique([planId, dayIndex])
}
